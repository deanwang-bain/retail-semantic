# ─────────────────────────────────────────────────────────────────────────────
# Retail Ontology Demo — environment variables
#
# The app runs fully WITHOUT any API keys. Leave everything blank (or copy
# this file to .env as-is) and you get:
#   • Local embeddings via @xenova/transformers (Xenova/all-MiniLM-L6-v2)
#   • Deterministic rule-based NL parsing / extraction
#
# Optional keys unlock hosted providers when present.
# ─────────────────────────────────────────────────────────────────────────────

# Neo4j (defaults match docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontology-demo

# Postgres + pgvector (defaults match docker-compose.yml)
DATABASE_URL=postgresql://ontology:ontology-demo@localhost:5432/retail_semantic

# ── Optional: hosted embeddings (first match wins) ──────────────────────────
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ── Optional: Claude for NL understanding + ingestion extraction ────────────
# ANTHROPIC_API_KEY=

# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# VOYAGE_MODEL=voyage-3-lite
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
